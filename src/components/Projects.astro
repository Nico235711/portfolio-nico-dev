---
import ProjectDetails from "./ProjectDetails.astro"
const projects = [
  {
    name: "Clima App Zod",
    demo: "https://github.com/Nico235711/clima-app-zod",
    github: "https://github.com/Nico235711/clima-app-zod",
    decription: "Una app de clima que usa Zod para la validación de datos permite a los usuarios obtener información meteorológica en tiempo real de diferentes ubicaciones."
  }
]
---

<section class="text-center mt-20 space-y-3">
  <h2 class="text-2xl font-bold">Proyectos</h2>
  <div>
    {
      projects.map(project => (
        <ProjectDetails project={project} />
      ))
    }
  </div>
</section>