---
const socialLinks = [
  {
    name: "Github",
    href: "https://github.com/Nico235711",
    target: "_blank",
    class:
      "border-3 border-slate-400 py-1 px-2 rounded-md hover:bg-sky-600 hover:border-sky-600 transition-all",
  },
  {
    name: "LinkedIn",
    href: "https://www.linkedin.com/in/nicolaslopezvidueiros/",
    target: "_blank",
    class:
      "border-3 border-slate-400 py-1 px-2 rounded-md hover:bg-sky-600 hover:border-sky-600 transition-all",
  },
];
const year = new Date().getFullYear();
---

<footer class="bg-slate-900 py-10 text-white mt-20">
  <div
    class="max-w-[400px] md:max-w-[600px] lg:max-w-[1000px] mx-auto flex flex-col items-center mt-5 md:flex-row md:justify-between space-y-5 md:space-y-0"
  >
    <p>Portfolio de Nicolás Lopez Vidueiros - {year}</p>
    <div class="flex gap-5">
      {
        socialLinks.map((link) => (
          <a
            href={`${link.href}`}
            target={`${link.target}`}
            class={`${link.class}`}
          >
            {link.name}
          </a>
        ))
      }
    </div>
  </div>
</footer>
