<section
  class="text-center mt-20 space-y-3 lg:w-[800px] mx-auto"
  id="contact"
>
  <h2 class="text-2xl font-bold">Contactame</h2>
  <form
    class="space-y-3 border-4 border-slate-300 p-5 rounded-md shadow"
    action="https://formspree.io/f/xqakzjpr"
    method="post"
  >
    <div class="flex gap-2">
      <label for="name" class="basis-1/6">Nombre</label>
      <input
        type="text"
        class="flex-1 border-2 border-slate-300 rounded-md"
        id="name"
        name="name"
      >
    </div>
    <div class="flex gap-2">
      <label for="email" class="basis-1/6">Email</label>
      <input
        type="email"
        class="flex-1 border-2 border-slate-300 rounded-md"
        id="email"
        name="email"
      >
    </div>
    <div class="flex gap-2">
      <label for="message" class="basis-1/6">Mensaje</label>
      <textarea name="message" id="message" class="flex-1 border-2 border-slate-300 rounded-md"></textarea>
    </div>
    <button
      type="submit"
      class="bg-sky-500 w-full md:w-auto py-2 md:px-10 rounded-md text-white uppercase hover:bg-sky-600 transition-all cursor-pointer"
    >Enviar</button>
  </form>
</section>