---
import Github from "./icons/Github.astro";
import World from "./icons/World.astro";

const { project } = Astro.props;
const { name, demo, github, description, image } = project;
---

<div class="space-y-3 border-4 border-slate-300 p-5 text-left rounded-md flex flex-col justify-between">
  <h3 class="text-2xl font-black">{name}</h3>
  <p class="text-lg">{description}</p>
  <div class="flex gap-5 justify-center flex-wrap">
    <a
      href={github}
      target="_blank"
      class="border-2 border-gray-300 py-1 px-10 rounded-md hover:bg-sky-600 transition-all"
    >
      <Github />
    </a>
    <a
      href={demo}
      target="_blank"
      class="border-2 border-gray-300 py-1 px-10 rounded-md hover:bg-sky-600 transition-all"
    >
      <World />
    </a>
  </div>
</div>
